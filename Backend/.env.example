APP_NAME=AI Support Ticket Classification API
APP_VERSION=1.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
FAISS_USE_MMAP=true
PRELOAD_QWEN=true
LOCAL_MODELS_DIR=artifacts/models
LOCAL_GEN_DIRNAME=qwen2.5-1.5b-instruct
LOCAL_EMBED_DIRNAME=bge-base-en-v1.5

# traditional = TF-IDF nearest reply copy
# qwen = hybrid FAISS/BM25 retrieval + Qwen2.5 generation
RESPONSE_MODE=qwen
EMBED_MODEL_NAME=BAAI/bge-base-en-v1.5
GEN_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
EMBED_DEVICE=auto
GENERATION_DEVICE=auto
TOP_K=5
FAISS_WEIGHT=0.55
BM25_WEIGHT=0.45
RAG_CANDIDATE_POOL=50
MAX_NEW_TOKENS=120
